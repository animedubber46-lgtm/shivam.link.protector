{
  "version": 2,
  "name": "shivam-link-protector",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/proxy/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/([a-zA-Z0-9_-]+)",
      "destination": "/api/index.js"
    },
    {
      "source": "/",
      "destination": "/api/index.js"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  }
}
